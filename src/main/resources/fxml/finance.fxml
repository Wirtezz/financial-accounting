<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.finance.controller.FinanceFXController">
    <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

    <Label text="СИСТЕМА УЧЕТА ФИНАНСОВ" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" alignment="CENTER" maxWidth="Infinity"/>
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnTheme" text="Тема" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TabPane fx:id="mainTabPane">
        <Tab text="Все операции" closable="false">
            <VBox spacing="10">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <Label text="Список всех операций"/>
                <TableView fx:id="transactionsTable" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="colNumber" text="№" prefWidth="70" resizable="true"/>
                        <TableColumn fx:id="colType" text="Тип" prefWidth="120" resizable="true"/>
                        <TableColumn fx:id="colAmount" text="Сумма" prefWidth="150" resizable="true"/>
                        <TableColumn fx:id="colCategory" text="Категория" prefWidth="200" resizable="true"/>
                        <TableColumn fx:id="colDescription" text="Описание" prefWidth="300" resizable="true"/>
                        <TableColumn fx:id="colDate" text="Дата" prefWidth="130" resizable="true"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Добавить операцию" closable="false">
            <VBox spacing="15">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <Label text="Добавление новой операции" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <GridPane hgap="10" vgap="10">
                    <Label text="Тип:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbType" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>

                    <Label text="Описание:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtDescription" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="400"/>

                    <Label text="Категория:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtCategory" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="300"/>

                    <Label text="Сумма (руб):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtAmount" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="200"/>

                    <Label text="Дата:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <HBox spacing="10" GridPane.rowIndex="4" GridPane.columnIndex="1">
                        <TextField fx:id="txtDay" promptText="День" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="txtMonth" promptText="Месяц" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="txtYear" promptText="Год" prefWidth="120"/>
                    </HBox>

                    <Button fx:id="btnAdd" text="ДОБАВИТЬ" GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="150" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </GridPane>
            </VBox>
        </Tab>

        <Tab text="Изменить" closable="false">
            <VBox spacing="15">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <Label text="Редактирование выбранной операции" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Label text="(Кликните на любую строку в таблице «Все операции» для загрузки данных)" style="-fx-font-style: italic; -fx-text-fill: gray;"/>

                <GridPane hgap="10" vgap="10">
                    <Label text="ID (не редактируется):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="editId" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="100"/>

                    <Label text="Тип:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="editType" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200"/>

                    <Label text="Описание:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="editDescription" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="400"/>

                    <Label text="Категория:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="editCategory" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="300"/>

                    <Label text="Сумма (руб):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="editAmount" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="200"/>

                    <Label text="Дата:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <HBox spacing="10" GridPane.rowIndex="5" GridPane.columnIndex="1">
                        <TextField fx:id="editDay" promptText="День" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="editMonth" promptText="Месяц" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="editYear" promptText="Год" prefWidth="120"/>
                    </HBox>

                    <Button fx:id="btnUpdate" text="СОХРАНИТЬ ИЗМЕНЕНИЯ" GridPane.rowIndex="6" GridPane.columnIndex="1" prefWidth="200" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </GridPane>
            </VBox>
        </Tab>

        <Tab text="Отчеты" closable="false">
            <VBox spacing="15">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <Label text="Отчет за период" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <GridPane hgap="15" vgap="15">
                    <Label text="Начальная дата:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <HBox spacing="10" GridPane.rowIndex="0" GridPane.columnIndex="1">
                        <TextField fx:id="txtStartDay" promptText="День" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="txtStartMonth" promptText="Месяц" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="txtStartYear" promptText="Год" prefWidth="120"/>
                    </HBox>

                    <Label text="Конечная дата:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <HBox spacing="10" GridPane.rowIndex="1" GridPane.columnIndex="1">
                        <TextField fx:id="txtEndDay" promptText="День" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="txtEndMonth" promptText="Месяц" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="txtEndYear" promptText="Год" prefWidth="120"/>
                    </HBox>

                    <Button fx:id="btnShowReport" text="ПОКАЗАТЬ ОТЧЕТ" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </GridPane>

                <Label text="Результат отчета:" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="reportArea" editable="false" wrapText="true" prefHeight="300"/>
            </VBox>
        </Tab>

        <Tab text="Удалить" closable="false">
            <VBox spacing="15" alignment="CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="Удаление операции по номеру строки (№)" style="-fx-font-weight: bold;"/>
                <HBox spacing="15" alignment="CENTER">
                    <Label text="Введите номер №:"/>
                    <TextField fx:id="txtDeleteId" prefWidth="150" promptText="Например: 1"/>
                    <Button fx:id="btnDelete" text="УДАЛИТЬ" prefWidth="120" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
                <Label fx:id="lblDeleteStatus" style="-fx-text-fill: gray;"/>
            </VBox>
        </Tab>

        <Tab text="График" closable="false">
            <VBox spacing="15">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <Label text="Динамика накопленного баланса" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <GridPane hgap="15" vgap="15">
                    <Label text="Начальная дата:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <HBox spacing="10" GridPane.rowIndex="0" GridPane.columnIndex="1">
                        <TextField fx:id="chartStartDay" promptText="День" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="chartStartMonth" promptText="Месяц" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="chartStartYear" promptText="Год" prefWidth="120"/>
                    </HBox>

                    <Label text="Конечная дата:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <HBox spacing="10" GridPane.rowIndex="1" GridPane.columnIndex="1">
                        <TextField fx:id="chartEndDay" promptText="День" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="chartEndMonth" promptText="Месяц" prefWidth="80"/>
                        <Label text="."/>
                        <TextField fx:id="chartEndYear" promptText="Год" prefWidth="120"/>
                    </HBox>

                    <Button fx:id="btnBuildChart" text="ПОСТРОИТЬ ГРАФИК" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200" style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </GridPane>

                <LineChart fx:id="financeChart" title="Накопленный баланс" VBox.vgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis label="Дата" fx:id="xAxis"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Баланс (руб.)" fx:id="yAxis"/>
                    </yAxis>
                </LineChart>
            </VBox>
        </Tab>

        <Tab text="Планировщик" closable="false">
            <VBox spacing="15">
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

                <Label text="Регулярные ежемесячные платежи" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

                <!-- Панель добавления -->
                <GridPane hgap="10" vgap="10">
                    <Label text="Тип:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="schedType" prefWidth="120" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Категория:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <TextField fx:id="schedCategory" prefWidth="150" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                    <Label text="Описание:" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
                    <TextField fx:id="schedDescription" prefWidth="200" GridPane.rowIndex="0" GridPane.columnIndex="5"/>

                    <Label text="Сумма:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="schedAmount" prefWidth="120" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="День месяца:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="schedDay" prefWidth="80" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                    <Button fx:id="btnAddScheduled" text="ДОБАВИТЬ" GridPane.rowIndex="1" GridPane.columnIndex="5"
                            prefWidth="120" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                </GridPane>

                <!-- Таблица регулярных операций -->
                <TableView fx:id="scheduledTable" prefHeight="250" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colSchedId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colSchedType" text="Тип" prefWidth="100"/>
                        <TableColumn fx:id="colSchedCategory" text="Категория" prefWidth="160"/>
                        <TableColumn fx:id="colSchedDescription" text="Описание" prefWidth="220"/>
                        <TableColumn fx:id="colSchedAmount" text="Сумма" prefWidth="120"/>
                        <TableColumn fx:id="colSchedDay" text="День месяца" prefWidth="120"/>
                        <TableColumn fx:id="colSchedLast" text="Последний запуск" prefWidth="150"/>
                        <TableColumn fx:id="colSchedDelete" text="Удалить" prefWidth="80"/>
                    </columns>
                </TableView>

                <Label fx:id="schedInfo" style="-fx-text-fill: gray;"/>
            </VBox>
        </Tab>
    </TabPane>

    <HBox spacing="30" alignment="CENTER">
        <Label text="Доходы:"/>
        <Label fx:id="lblTotalIncome" text="0.00 руб."/>
        <Label text="Расходы:"/>
        <Label fx:id="lblTotalExpense" text="0.00 руб."/>
        <Label text="Баланс:"/>
        <Label fx:id="lblBalance" text="0.00 руб."/>
    </HBox>
</VBox>
